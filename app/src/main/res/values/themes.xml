<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppGimnasio" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main system colors -->
        <item name="colorPrimary">@color/yellow_gym</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
    </style>

    <style name="Theme.AppGimnasio" parent="Base.Theme.AppGimnasio" />

    <!-- Estilo para títulos -->
    <style name="titulo">
        <item name="android:textSize">25sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- Estilo para botones principales -->
    <style name="btnPrimary">
        <item name="backgroundTint">@color/yellow_gym</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="btn_cerrarsesion">
        <item name="backgroundTint">@color/red </item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">8dp</item>

    </style>
</resources>